# ── Dgraph ────────────────────────────────────────────────────────────────────
DGRAPH_ALPHA_HOST=dgraph-alpha
DGRAPH_ALPHA_PORT=9080

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=9090
API_ADMIN_TOKEN=changeme
LOG_LEVEL=info

# ── AIS — aisstream.io WebSocket ──────────────────────────────────────────────
# Free API key: https://aisstream.io (register, key generated instantly)
# Leave empty to disable AIS live feed (system still works with manual pushes)
AIS_STREAM_API_KEY=
AIS_STREAM_URL=wss://stream.aisstream.io/v0/stream
AIS_RECONNECT_DELAY=30s

# Comma-separated list of bounding box names to subscribe to.
# Available: cn_gaolan_zhuhai, cn_taicang, cn_tianjin, cn_qingdao, cn_shanghai,
#            hormuz_chokepoint, ir_chabahar, ir_bandar_abbas, ir_bushehr, ir_khorramshahr
# Leave empty to use all defaults.
AIS_WATCH_AREAS=

# ── OFAC SDN List ─────────────────────────────────────────────────────────────
# US Treasury, public, no auth required.
# https://www.treasury.gov/ofac/downloads/sdn.xml
OFAC_ENABLED=true
OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn.xml
OFAC_UPDATE_INTERVAL=24h

# ── UN Security Council Consolidated List ─────────────────────────────────────
# Public, no auth required.
# https://scsanctions.un.org/resources/xml/en/consolidated.xml
UN_SANCTIONS_ENABLED=true
UN_SANCTIONS_URL=https://scsanctions.un.org/resources/xml/en/consolidated.xml
UN_UPDATE_INTERVAL=24h

# ── EU RELEX Financial Sanctions ──────────────────────────────────────────────
# Requires free registration token at:
# https://webgate.ec.europa.eu/europeaid/fsd/fsf#!/account
# Set EU_SANCTIONS_ENABLED=true only when token is configured.
EU_SANCTIONS_ENABLED=false
EU_SANCTIONS_URL=https://webgate.ec.europa.eu/europeaid/fsd/fsf/public/files/xmlFullSanctionsList_1_1/content
EU_SANCTIONS_TOKEN=
EU_UPDATE_INTERVAL=24h

# ── Vessel cross-source verification ──────────────────────────────────────────
# VesselFinder REST API v2 — https://api.vesselfinder.com/
# Paid API key required. Leave empty to disable VesselFinder source.
VESSEL_FINDER_API_KEY=

# MyShipTracking public endpoint (free, limited calls/day).
# Set to false to disable.
MYSHIPTRACKING_ENABLED=true

# How often to re-verify all tracked vessels (default: every 6 hours).
VESSEL_VERIFY_INTERVAL=6h

# ── MarineTraffic port surveillance ───────────────────────────────────────────
# Paid API key required. Leave empty to disable.
# https://www.marinetraffic.com/en/ais-api-services
MARINETRAFFIC_API_KEY=
PORT_WATCH_INTERVAL=1h
# Days of route history to keep before pruning old positions.
ROUTE_PRUNE_DAYS=30

# ── MyShipTracking zone poller ────────────────────────────────────────────────
# Free API key (limited): https://www.myshiptracking.com/developers
# Leave empty to disable zone-based vessel discovery.
MYSHIPTRACKING_API_KEY=
MST_POLL_INTERVAL=2h

# ── Datalastic vessel enricher ────────────────────────────────────────────────
# Free tier available: https://datalastic.com
# Leave empty to disable.
DATALASTIC_API_KEY=
DATALASTIC_ENRICH_INTERVAL=4h
# Max vessels enriched per cycle (default: 25, keep low on free tier).
DATALASTIC_ENRICH_BATCH=25

# ── MarineTraffic web scraper (no key required) ────────────────────────────────
# Scrapes the MarineTraffic tile endpoint for vessels in Iranian port zones.
# Set to false to disable.
MT_SCRAPER_ENABLED=true
MT_SCRAPE_INTERVAL=3h

# ── Global Fishing Watch (free tier) ──────────────────────────────────────────
# Free API key: https://globalfishingwatch.org/our-apis/
# Enables historical Iran port-visit detection for known vessels.
# Leave empty to disable.
GFW_API_KEY=
GFW_POLL_INTERVAL=6h
